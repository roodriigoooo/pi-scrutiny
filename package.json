{
  "name": "@roodriigoooo/pi-scrutiny",
  "version": "0.2.0",
  "description": "Pi Scrutiny: multi-model panel consultation for Pi coding agent",
  "keywords": [
    "pi-package",
    "pi-extension",
    "scrutiny",
    "multi-model",
    "coding-agent"
  ],
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roodriigoooo/pi-scrutiny.git"
  },
  "files": [
    "extensions",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions/scrutiny.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "eval:templates": "node --import ./eval/_ts-resolve.ts --experimental-strip-types eval/templates-test.ts",
    "eval:setup": "node --import ./eval/_ts-resolve.ts --experimental-strip-types eval/setup-test.ts",
    "eval:boundaries": "node --import ./eval/_ts-resolve.ts --experimental-strip-types eval/control-boundary-test.ts",
    "eval:smoke": "node --experimental-strip-types eval/run-eval.ts smoke",
    "eval:coverage": "node --import ./eval/_ts-resolve.ts --experimental-strip-types eval/coverage.ts",
    "eval:scout": "node --import ./eval/_ts-resolve.ts --experimental-strip-types eval/scout-test.ts",
    "eval:artifacts": "node --experimental-strip-types eval/artifacts-test.ts",
    "eval:verify": "node --import ./eval/_ts-resolve.ts --experimental-strip-types eval/verify-test.ts",
    "eval:normalize": "node --experimental-strip-types eval/normalize-test.ts",
    "pack:dry": "npm pack --dry-run",
    "release:dry": "npm run check && npm run pack:dry",
    "smoke:help": "pi --no-extensions -e ./extensions/scrutiny.ts --mode json --no-session \"/scrutiny help\""
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
